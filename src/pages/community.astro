---
// =============================================================================
// COMMUNITY PAGINA (/community)
// Beheerder [Decadence] kan deze pagina aanpassen door dit bestand op GitHub
// te bewerken. De staff-lijst komt uit src/content/staff/staff.json.
// De content creators (`creators` array hieronder) en de Discord-uitnodiging
// (zoek "discord.gg" verderop in dit bestand) wijzig je hier direct.
// =============================================================================
import Base from '~/layouts/Base.astro';
import CTA from '~/components/CTA.astro';
import { getCollection } from 'astro:content';

const staff = (await getCollection('staff')).map((s) => s.data);
const creators = [
  { name: 'TBD', role: 'Streamer / YouTuber', note: 'Content creators we partner with.' },
];
---
<Base
  title="Community"
  description="The OutbreakDayZ community. Discord, staff, and content creators."
>
  <section class="container page-head">
    <p class="eyebrow">// The squad</p>
    <h1>Community</h1>
    <p class="lede">
      A community is more than a server. Drop into Discord, meet the staff,
      run with the creators.
    </p>
  </section>

  <section class="container discord">
    <div class="discord-card brackets" data-reveal>
      <div>
        <p class="eyebrow-2">// Discord</p>
        <h2>Where we organize, recruit, and run events.</h2>
        <p>
          Get the launch order, sign up for events, and find a squad. Mods and admins
          live in Discord. Reports go through tickets, not @everyone.
        </p>
        <a class="btn btn-primary" href="https://discord.gg/" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          Join our Discord
        </a>
      </div>
      <p class="badge" aria-hidden="true">// COMMS</p>
    </div>
  </section>

  <section class="container">
    <h2>Staff</h2>
    <p class="lede">The people who keep the lights on.</p>
    <ul class="staff-grid">
      {staff.map((s) => (
        <li class="card brackets" data-reveal>
          <div class="avatar" aria-hidden="true">{s.name.charAt(0)}</div>
          <div>
            <h3>{s.name}</h3>
            <p class="role">{s.role}</p>
            {s.bio && <p class="bio">{s.bio}</p>}
          </div>
        </li>
      ))}
    </ul>
  </section>

  <section class="container">
    <h2>Content Creators</h2>
    <p class="lede">Streaming or making videos on our servers? Tag us. We'll feature you.</p>
    <ul class="creator-grid">
      {creators.map((c) => (
        <li class="card brackets" data-reveal>
          <h3>{c.name}</h3>
          <p class="role">{c.role}</p>
          <p class="bio">{c.note}</p>
        </li>
      ))}
    </ul>
  </section>

  <CTA
    title="Roll with the dead"
    body="Discord is the front door. Get in there."
    primary={{ href: 'https://discord.gg/', label: 'Join Discord' }}
  />
</Base>

<style>
  .page-head { padding-block: clamp(3rem, 6vw, 5rem) clamp(2rem, 4vw, 3rem); }
  .eyebrow,
  .eyebrow-2 {
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    color: var(--rust);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.85rem;
    margin: 0 0 0.5rem;
  }
  .lede { color: var(--text-dim); max-width: 60ch; margin-bottom: 1.5rem; }
  .discord-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    background: linear-gradient(180deg, rgba(88, 101, 242, 0.06), transparent);
    border: 1px solid var(--border);
    padding: clamp(1.5rem, 4vw, 3rem);
  }
  .discord-card h2 { margin: 0 0 1rem; max-width: 22ch; }
  .discord-card p { color: var(--text-dim); margin: 0 0 1.5rem; max-width: 50ch; }
  .badge {
    align-self: end;
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    color: var(--text-muted);
    letter-spacing: 0.18em;
    margin: 0;
    writing-mode: vertical-rl;
  }
  @media (max-width: 720px) {
    .discord-card { grid-template-columns: 1fr; }
    .badge { display: none; }
  }

  .staff-grid,
  .creator-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }
  .staff-grid li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: start;
  }
  .avatar {
    width: 56px;
    height: 56px;
    border: 1px solid var(--border);
    background: var(--bg-2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    font-weight: 800;
    font-size: 1.6rem;
    color: var(--blood-bright);
  }
  h3 { margin: 0 0 0.25rem; font-size: 1.1rem; }
  .role { color: var(--rust); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 0.5rem; font-family: 'Big Shoulders Stencil Display', sans-serif; }
  .bio { color: var(--text-dim); margin: 0; font-size: 0.9rem; }
</style>
