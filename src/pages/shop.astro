---
import Base from '~/layouts/Base.astro';

const tiers = [
  {
    name: 'Survivor',
    price: 5,
    period: 'mo',
    perks: [
      'Custom in-game tag',
      'Discord donor role',
      'Cosmetic skin pack',
      'Our undying gratitude',
    ],
  },
  {
    name: 'Operator',
    price: 10,
    period: 'mo',
    perks: [
      'Everything in Survivor',
      'Priority queue when full',
      'Reserved Discord channel access',
      'Early event RSVP',
    ],
    featured: true,
  },
  {
    name: 'Veteran',
    price: 25,
    period: 'mo',
    perks: [
      'Everything in Operator',
      'Custom Discord role color',
      'Direct line to the admin team',
      'Name on our wall',
    ],
  },
];
---
<Base
  title="Support the Server"
  description="Donation tiers for OutbreakDayZ. Cosmetic perks only — no pay-to-win, ever."
>
  <section class="container page-head">
    <p class="eyebrow">// Funding the lights</p>
    <h1>Support the Server</h1>
    <p class="lede">
      Hosting isn't free. If you're getting your money's worth out of the server,
      kick a few bucks our way. <strong>No pay-to-win. Ever.</strong> Perks are cosmetic
      and quality-of-life only.
    </p>
  </section>

  <section class="container">
    <ul class="tiers">
      {tiers.map((t) => (
        <li class={`tier card brackets ${t.featured ? 'featured' : ''}`} data-reveal>
          {t.featured && <p class="ribbon">// Most picked</p>}
          <h3>{t.name}</h3>
          <p class="price">
            <span class="dollar">$</span>
            <span class="amount">{t.price}</span>
            <span class="period">/ {t.period}</span>
          </p>
          <ul class="perks">
            {t.perks.map((p) => <li>{p}</li>)}
          </ul>
          <a class="btn btn-primary" href="#" data-tier={t.name}>Choose {t.name}</a>
        </li>
      ))}
    </ul>

    <p class="note">
      Payments are processed by Tebex. Refunds within 7 days, no questions asked.
      Have an issue? <a class="link" href="/community">Open a ticket in Discord</a>.
    </p>
  </section>
</Base>

<style>
  .page-head { padding-block: clamp(3rem, 6vw, 5rem) clamp(2rem, 4vw, 3rem); }
  .eyebrow {
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    color: var(--rust);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.85rem;
    margin: 0 0 0.5rem;
  }
  .lede { color: var(--text-dim); max-width: 60ch; }
  .tiers {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    align-items: stretch;
  }
  .tier {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }
  .featured {
    border-color: var(--blood);
    background: linear-gradient(180deg, rgba(178, 34, 34, 0.08), var(--surface));
  }
  .ribbon {
    position: absolute;
    top: -10px;
    left: 1rem;
    background: var(--blood);
    color: var(--text);
    padding: 0.25rem 0.6rem;
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    margin: 0;
  }
  h3 { margin: 0; font-size: 1.5rem; }
  .price {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    color: var(--text);
    margin: 0;
  }
  .dollar {
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    color: var(--rust);
    font-size: 1.5rem;
  }
  .amount {
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    font-weight: 800;
    font-size: 3.5rem;
    line-height: 1;
    color: var(--text);
  }
  .period {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
  }
  .perks {
    list-style: none;
    padding: 0;
    margin: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
  .perks li {
    color: var(--text-dim);
    position: relative;
    padding-left: 1.4rem;
    font-size: 0.95rem;
  }
  .perks li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 10px;
    height: 1px;
    background: var(--blood-bright);
  }
  .note {
    margin-top: 2.5rem;
    color: var(--text-dim);
    border-left: 2px solid var(--blood);
    padding: 0.5rem 1rem;
  }
  .link { color: var(--rust); text-decoration: underline; text-underline-offset: 4px; }
</style>
