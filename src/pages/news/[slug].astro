---
// =============================================================================
// NIEUWS DETAIL PAGINA (/news/<slug>)
// Beheerder [Decadence] hoeft dit bestand normaal niet aan te raken — het is
// de mal waar elk nieuwsbericht in getoond wordt. Wil je een nieuwsbericht
// wijzigen? Bewerk dan het juiste .mdx bestand in:
//   src/content/news/<bericht-naam>.mdx
// De bestandsnaam (zonder .mdx) bepaalt de URL (slug).
// =============================================================================
import Article from '~/layouts/Article.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((p) => ({ params: { slug: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Article
  title={entry.data.title}
  description={entry.data.excerpt}
  date={entry.data.date}
  author={entry.data.author}
  hero={entry.data.hero}
>
  <Content />
</Article>
