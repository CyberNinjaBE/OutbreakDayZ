---
// =============================================================================
// NEWS DETAIL PAGE  (/news/<slug>)
//
// HEY DECADENCE - You normally do NOT need to touch this file. It's the
// template that wraps every single news post. The actual post content
// lives in the .mdx files.
//
// To change the text of one specific post, edit the matching file in:
//   src/content/news/<post-name>.mdx
// The file name (without .mdx) is what shows up in the URL.
// =============================================================================
import Article from '~/layouts/Article.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((p) => ({ params: { slug: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Article
  title={entry.data.title}
  description={entry.data.excerpt}
  date={entry.data.date}
  author={entry.data.author}
  hero={entry.data.hero}
>
  <Content />
</Article>
