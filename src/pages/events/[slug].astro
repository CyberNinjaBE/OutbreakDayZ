---
// =============================================================================
// EVENT DETAIL PAGE  (/events/<slug>)
//
// HEY DECAD3NCE - You normally do NOT need to touch this file. It's the
// template that wraps every single event. The actual event content lives in
// the .mdx files.
//
// To change the text of one specific event, edit the matching file in:
//   src/content/events/<event-name>.mdx
// The file name (without .mdx) is what shows up in the URL.
// =============================================================================
import Base from '~/layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((e) => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const formatter = new Intl.DateTimeFormat('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---
<Base
  title={entry.data.title}
  description={entry.data.summary ?? `OutbreakDayZ event on ${formatter.format(entry.data.date)}`}
  type="article"
>
  <article class="container event-article">
    <header class="event-head">
      <p class="eyebrow">// Event briefing</p>
      <h1>{entry.data.title}</h1>
      <p class="meta">
        <time datetime={entry.data.date.toISOString()}>{formatter.format(entry.data.date)}</time>
        {entry.data.location && <><span class="sep">·</span><span>{entry.data.location}</span></>}
      </p>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="back">
      <a class="btn" href="/events">&larr; All events</a>
    </footer>
  </article>
</Base>

<style>
  .event-article { padding-block: clamp(3rem, 6vw, 5rem); max-width: 740px; }
  .eyebrow {
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    color: var(--rust);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.85rem;
    margin: 0 0 0.5rem;
  }
  .event-head { margin-bottom: 2rem; }
  .meta {
    color: var(--text-muted);
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
  }
  .sep { margin: 0 0.6rem; }
  .prose :global(h2) {
    margin-top: 2rem;
    color: var(--rust);
    font-size: 1.5rem;
  }
  .prose :global(p) { color: var(--text-dim); }
  .prose :global(strong) { color: var(--text); }
  .prose :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .prose :global(ul li) {
    position: relative;
    padding-left: 1.5rem;
    color: var(--text-dim);
  }
  .prose :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 10px;
    height: 1px;
    background: var(--blood-bright);
  }
  .back { margin-top: 3rem; }
</style>
