---
// =============================================================================
// FOOTER  (the strip at the bottom of every page)
//
// HEY DECADENCE - You can edit the footer yourself.
//
// What's in the footer:
//   - The tagline ("A community of survivors...")
//   - Three columns of links (Server, Community, About)
//   - The copyright line at the bottom
//
// All of that is right below in plain HTML. Just look for the words
// between the > and < signs and change them. Don't touch anything inside
// <... > or anything between { ... } — that's code.
// =============================================================================
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="brand-line">
        <span class="brand-prefix">Outbreak</span><span class="brand-suffix">DayZ</span>
      </p>
      <p class="tagline">A community of survivors. The dead don't sleep.</p>
    </div>

    <nav aria-label="Footer">
      <h4>Server</h4>
      <ul>
        <li><a href="/servers">Servers</a></li>
        <li><a href="/how-to-connect">How to Connect</a></li>
        <li><a href="/rules">Rules</a></li>
        <li><a href="/mods">Mods</a></li>
      </ul>
    </nav>

    <nav aria-label="Community">
      <h4>Community</h4>
      <ul>
        <li><a href="/events">Events</a></li>
        <li><a href="/community">Discord & Staff</a></li>
        <li><a href="/shop">Support the Server</a></li>
        <li><a href="/news">News</a></li>
      </ul>
    </nav>

    <nav aria-label="Legal">
      <h4>About</h4>
      <ul>
        <li><a href="https://dayz.com" rel="noopener noreferrer">DayZ Official</a></li>
      </ul>
    </nav>
  </div>

  <div class="container bottom">
    <p>&copy; {year} OutbreakDayZ. Not affiliated with Bohemia Interactive.</p>
    <p class="stencil">{`// SECTOR ${year} //`}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: linear-gradient(180deg, transparent 0%, rgba(7, 7, 7, 0.6) 100%);
    margin-top: clamp(4rem, 8vw, 6rem);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: 2rem;
    padding-block: 3rem 2rem;
  }
  @media (max-width: 720px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
  .brand-line {
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .brand-suffix { color: var(--blood-bright); }
  .tagline { color: var(--text-dim); font-size: 0.95rem; }
  h4 {
    font-size: 0.95rem;
    color: var(--rust);
    margin-bottom: 0.75rem;
  }
  .footer-grid ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-grid a {
    color: var(--text-dim);
    transition: color 0.15s ease;
  }
  .footer-grid a:hover { color: var(--text); }
  .bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.5rem 2rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.85rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .stencil {
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }
</style>
