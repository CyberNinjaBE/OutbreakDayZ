---
interface POI {
  x: number;
  y: number;
  label: string;
  kind: 'safezone' | 'military' | 'pvp' | 'event';
}
const pois: POI[] = [
  { x: 28, y: 82, label: 'Cherno Trader', kind: 'safezone' },
  { x: 78, y: 78, label: 'Berezino Pier', kind: 'pvp' },
  { x: 18, y: 38, label: 'NWAF', kind: 'military' },
  { x: 58, y: 24, label: 'Tisy', kind: 'military' },
  { x: 70, y: 52, label: 'NEAF', kind: 'military' },
  { x: 42, y: 60, label: 'Green Mtn Trader', kind: 'safezone' },
  { x: 92, y: 30, label: 'Convoy Drop', kind: 'event' },
];
---
<div class="map-wrap brackets" data-reveal>
  <svg viewBox="0 0 100 100" role="img" aria-label="Operational map of Chernarus with points of interest">
    <defs>
      <pattern id="grid" width="5" height="5" patternUnits="userSpaceOnUse">
        <path d="M 5 0 L 0 0 0 5" fill="none" stroke="rgba(232,226,212,0.04)" stroke-width="0.15"/>
      </pattern>
      <linearGradient id="terrain" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#161412"/>
        <stop offset="100%" stop-color="#0c0b0a"/>
      </linearGradient>
    </defs>
    <rect width="100" height="100" fill="url(#terrain)"/>
    <rect width="100" height="100" fill="url(#grid)"/>

    <!-- Coastline approximation -->
    <path d="M 0 95 Q 18 88 30 86 T 60 84 Q 78 82 90 78 L 100 76 L 100 100 L 0 100 Z"
      fill="rgba(74, 90, 58, 0.12)" stroke="rgba(74, 90, 58, 0.4)" stroke-width="0.25"/>
    <!-- Mountains -->
    <path d="M 30 30 L 40 22 L 48 28 L 56 18 L 70 26 L 78 20 L 88 30 L 80 38 L 60 36 L 40 38 Z"
      fill="rgba(168, 82, 30, 0.06)" stroke="rgba(168, 82, 30, 0.3)" stroke-width="0.2"/>
    <!-- Roads -->
    <path d="M 12 90 L 30 78 L 50 72 L 70 60 L 86 40 L 92 28" stroke="rgba(178, 34, 34, 0.4)" stroke-width="0.35" fill="none" stroke-dasharray="0.8 0.8"/>

    {pois.map((p) => (
      <g class={`poi poi-${p.kind}`} transform={`translate(${p.x} ${p.y})`}>
        <circle r="1.6" />
        <circle r="3" fill="none" class="ring"/>
        <text x="3.5" y="1.2" font-family="Big Shoulders Stencil Display, sans-serif" font-size="2" font-weight="800" fill="currentColor">{p.label}</text>
      </g>
    ))}
  </svg>

  <ul class="legend">
    <li><span class="dot legend-safezone"></span>Safezone</li>
    <li><span class="dot legend-military"></span>Military</li>
    <li><span class="dot legend-pvp"></span>PVP Hot Zone</li>
    <li><span class="dot legend-event"></span>Active Event</li>
  </ul>
</div>

<style>
  .map-wrap {
    position: relative;
    border: 1px solid var(--border);
    background: var(--bg-2);
    padding: 0.5rem;
  }
  svg {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1 / 1;
  }
  .poi text {
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .poi-safezone { color: var(--mil); }
  .poi-military { color: var(--rust); }
  .poi-pvp { color: var(--blood-bright); }
  .poi-event { color: var(--warning); }

  .poi circle:first-of-type { fill: currentColor; }
  .poi .ring {
    stroke: currentColor;
    stroke-width: 0.3;
    opacity: 0.6;
  }

  .legend {
    list-style: none;
    padding: 0.85rem 0;
    margin: 0;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    border-top: 1px solid var(--border);
    margin-top: 0.5rem;
    color: var(--text-dim);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: 'Big Shoulders Stencil Display', sans-serif;
  }
  .legend li { display: inline-flex; align-items: center; gap: 0.5rem; }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .legend-safezone { background: var(--mil); }
  .legend-military { background: var(--rust); }
  .legend-pvp { background: var(--blood-bright); }
  .legend-event { background: var(--warning); }
</style>
