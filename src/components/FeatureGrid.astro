---
interface Feature {
  title: string;
  body: string;
  icon: string;
}
const features: Feature[] = [
  {
    icon: 'crosshair',
    title: 'Hardcore Survival',
    body: 'Tuned loot, dense infected, and a winter that does not forgive. Closer to vanilla than to power-fantasy.',
  },
  {
    icon: 'shield',
    title: 'Active Admins',
    body: 'A real staff team. On Discord daily. Tickets answered in hours, not weeks.',
  },
  {
    icon: 'zap',
    title: 'Low Latency',
    body: 'US East metal. 60 Hz tick. Stable through the wipe.',
  },
  {
    icon: 'users',
    title: 'Community First',
    body: 'No pay-to-win. Cosmetic perks only. The donation page is for keeping the lights on.',
  },
  {
    icon: 'map',
    title: 'Three Maps',
    body: 'Chernarus, Livonia, Namalsk. Pick your poison. Same staff, same rules.',
  },
  {
    icon: 'flag',
    title: 'Weekly Events',
    body: 'Convoy runs, KOTH, hostage rescues. Sign up in Discord. Loot rewards. Real stakes.',
  },
];

const Icon = (name: string) => {
  switch (name) {
    case 'crosshair': return '<circle cx="12" cy="12" r="9"/><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/>';
    case 'shield': return '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>';
    case 'zap': return '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>';
    case 'users': return '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>';
    case 'map': return '<polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/>';
    case 'flag': return '<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/>';
    default: return '';
  }
};
---
<div class="feature-grid">
  {features.map((f) => (
    <article class="feature card brackets" data-reveal>
      <span class="icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter" set:html={Icon(f.icon)}></svg>
      </span>
      <h3>{f.title}</h3>
      <p>{f.body}</p>
    </article>
  ))}
</div>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .feature {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .icon {
    color: var(--blood-bright);
    display: inline-flex;
    margin-bottom: 0.25rem;
  }
  h3 { margin: 0; font-size: 1.25rem; }
  p { color: var(--text-dim); margin: 0; }
</style>
