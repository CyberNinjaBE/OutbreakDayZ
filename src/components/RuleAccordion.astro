---
interface Props {
  title: string;
  category: string;
  summary?: string;
  open?: boolean;
}
const { title, category, summary, open = false } = Astro.props;
---
<details class="rule-accordion" open={open}>
  <summary>
    <span class="cat">{category}</span>
    <span class="title">{title}</span>
    {summary && <span class="sum">{summary}</span>}
    <span class="chev" aria-hidden="true">+</span>
  </summary>
  <div class="rule-body">
    <slot />
  </div>
</details>

<style>
  .rule-accordion {
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
  }
  .rule-accordion + .rule-accordion { border-top: 0; }
  summary {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    grid-template-rows: auto auto;
    align-items: center;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    column-gap: 1rem;
    transition: background-color 0.15s ease;
  }
  summary::-webkit-details-marker { display: none; }
  summary:hover { background: rgba(139, 26, 26, 0.05); }
  .cat {
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rust);
  }
  .title {
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 1.25rem;
  }
  .sum {
    grid-column: 2 / 3;
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-top: 0.15rem;
  }
  .chev {
    grid-column: 3;
    grid-row: 1 / 3;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Big Shoulders Stencil Display', sans-serif;
    font-size: 1.2rem;
    transition: transform 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  details[open] .chev {
    transform: rotate(45deg);
    color: var(--blood-bright);
    border-color: var(--blood);
  }
  .rule-body {
    padding: 0.5rem 1.25rem 1.5rem;
    color: var(--text-dim);
  }
  @media (max-width: 600px) {
    summary { grid-template-columns: 1fr auto; }
    .cat { grid-column: 1 / 3; }
    .title { grid-column: 1 / 3; }
    .sum { grid-column: 1 / 3; }
    .chev { grid-row: 1 / 4; }
  }
</style>
